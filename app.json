{
  "expo": {
    "name": "RizeSpring",
    "slug": "rizespring",
    "version": "1.0.1",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-navigation-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": false,
          "cameraPermission": false
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/cropedAppLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/cropedAppLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarHidden": true
      }
    },
    "android": {
      "package": "com.optisoft.rizespring",
      "versionCode": 4,
      "permissions": [],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/cropedAppLogo.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "statusBar": {
        "hidden": true,
        "translucent": true,
        "backgroundColor": "#000000"
      },
      "navigationBar": {
        "visible": "sticky-immersive",
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9529bf79-128d-467b-969d-39ee6c1129e3"
      }
    }
  }
}
