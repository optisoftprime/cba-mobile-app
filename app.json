{
  "expo": {
    "name": "RizeSpring",
    "slug": "rizespring",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": ["expo-router", "@react-native-community/datetimepicker"],
    "orientation": "portrait",
    "icon": "./assets/cropedAppLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/cropedAppLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarHidden": true
      }
    },
    "android": {
      "package": "com.optisoft.rizespring",
      "adaptiveIcon": {
        "foregroundImage": "./assets/cropedAppLogo.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "statusBar": {
        "hidden": true,
        "translucent": true,
        "backgroundColor": "#000000"
      },
      "navigationBar": {
        "visible": "sticky-immersive",
        "backgroundColor": "#000000",
        "barStyle": "dark-content"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9529bf79-128d-467b-969d-39ee6c1129e3"
      }
    }
  }
}
